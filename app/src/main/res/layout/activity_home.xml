<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA"
    android:fitsSystemWindows="true">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:gravity="center_vertical"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xin chào"
                android:textSize="11sp"
                android:textColor="#94A3B8" />

            <TextView
                android:id="@+id/tvChaoMung"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#0F172A"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnLichSuChat"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_avatar_circle"
            android:src="@android:drawable/ic_dialog_email"
            android:tint="#64748B"
            android:contentDescription="Lịch sử chat"
            android:padding="9dp"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btnLogout"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_avatar_circle"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#64748B"
            android:contentDescription="Đăng xuất"
            android:padding="9dp" />
    </LinearLayout>

    <!-- Banner ticket đang active -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardTicketActive"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#EEF4FF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="💬"
                android:textSize="18sp"
                android:gravity="center"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đang được hỗ trợ"
                    android:textSize="11sp"
                    android:textColor="#1976D2"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTicketActiveTieuDe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A" />

                <TextView
                    android:id="@+id/tvTicketActiveKtv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#64748B" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChatNow"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Chat"
                android:textSize="12sp"
                android:paddingHorizontal="14dp"
                app:cornerRadius="10dp"
                app:backgroundTint="#1976D2"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Section title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chọn sản phẩm cần hỗ trợ"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#0F172A"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp" />

    <!-- Danh sách sản phẩm -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSanPham"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false" />

</LinearLayout>
