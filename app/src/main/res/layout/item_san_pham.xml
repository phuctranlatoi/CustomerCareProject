<?xml version="1.0" encoding="utf-8"?>
<!-- Product card using Material3Card with 2dp elevation and hover effect -->
<com.example.customercareproject.ui.components.Material3Card xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardProduct"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cornerRadiusSize="medium"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
    app:cardClickable="true"
    app:enableHoverEffect="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Icon with circular background using MD3 primary container -->
        <TextView
            android:id="@+id/tvIconSanPham"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_avatar_circle"
            android:gravity="center"
            android:textSize="20sp"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Product name with MD3 typography -->
        <TextView
            android:id="@+id/tvTenSanPham"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorOnSurface"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.2" />

        <!-- Product description with MD3 typography -->
        <TextView
            android:id="@+id/tvMoTaSanPham"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.5" />
    </LinearLayout>

</com.example.customercareproject.ui.components.Material3Card>
