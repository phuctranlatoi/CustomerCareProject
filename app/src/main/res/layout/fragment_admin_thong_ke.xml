<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Filter chips -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/btnTuan"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="7 ngày"
                android:textSize="13sp"
                android:checkable="true"
                android:checked="true"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                app:chipBackgroundColor="@color/primary"
                android:textColor="@color/white"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnThang"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="30 ngày"
                android:textSize="13sp"
                android:checkable="true"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_marginEnd="8dp" />
        </LinearLayout>

        <!-- Stat cards 2x2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Card 1: Đánh giá SP -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="⭐"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_stat"
                        android:layout_marginBottom="10dp" />
                    <TextView
                        android:id="@+id/tvTongDanhGia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#0F172A" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đánh giá SP"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 2: Yêu cầu HT -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="🎫"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_stat"
                        android:layout_marginBottom="10dp" />
                    <TextView
                        android:id="@+id/tvTongTicket"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#0F172A" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Yêu cầu HT"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <!-- Card 3: Đánh giá KTV -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="👤"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_stat"
                        android:layout_marginBottom="10dp" />
                    <TextView
                        android:id="@+id/tvTongDanhGiaKtv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#0F172A" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đánh giá KTV"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 4: Điểm TB KTV -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="📊"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_stat"
                        android:layout_marginBottom="10dp" />
                    <TextView
                        android:id="@+id/tvDiemTBKtv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#0F172A" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Điểm TB KTV"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Trạng thái Ticket -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trạng thái Ticket"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="#F59E0B"
                        android:layout_marginEnd="10dp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Chờ xử lý"
                        android:textColor="#64748B"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/tvTicketChoXuLy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#F59E0B"
                        android:textStyle="bold"
                        android:textSize="15sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/primary"
                        android:layout_marginEnd="10dp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Đang xử lý"
                        android:textColor="#64748B"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/tvTicketDangXuLy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:textSize="15sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="#10B981"
                        android:layout_marginEnd="10dp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Đã xử lý"
                        android:textColor="#64748B"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/tvTicketDaXuLy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#10B981"
                        android:textStyle="bold"
                        android:textSize="15sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tỷ lệ hài lòng -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tỷ lệ hài lòng"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Hài lòng"
                        android:textSize="12sp"
                        android:textColor="#64748B" />
                    <ProgressBar
                        android:id="@+id/pbHaiLong"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="10dp"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:progressTint="#10B981"
                        android:progressBackgroundTint="#F1F5F9"
                        android:max="100"
                        android:progress="0" />
                    <TextView
                        android:id="@+id/tvHaiLong"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textColor="#10B981"
                        android:textStyle="bold"
                        android:gravity="end" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Trung bình"
                        android:textSize="12sp"
                        android:textColor="#64748B" />
                    <ProgressBar
                        android:id="@+id/pbTrungBinh"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="10dp"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:progressTint="#F59E0B"
                        android:progressBackgroundTint="#F1F5F9"
                        android:max="100"
                        android:progress="0" />
                    <TextView
                        android:id="@+id/tvTrungBinh"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textColor="#F59E0B"
                        android:textStyle="bold"
                        android:gravity="end" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Không HL"
                        android:textSize="12sp"
                        android:textColor="#64748B" />
                    <ProgressBar
                        android:id="@+id/pbKhongHaiLong"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="10dp"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:progressTint="#EF4444"
                        android:progressBackgroundTint="#F1F5F9"
                        android:max="100"
                        android:progress="0" />
                    <TextView
                        android:id="@+id/tvKhongHaiLong"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textColor="#EF4444"
                        android:textStyle="bold"
                        android:gravity="end" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Đánh giá theo sản phẩm -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đánh giá theo Sản phẩm"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A"
                    android:layout_marginBottom="12dp" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvThongKeSanPham"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Hiệu suất KTV -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">
<!--            <LinearLayout-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:orientation="vertical"-->
<!--                android:padding="20dp">-->
<!--                <TextView-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:text="Hiệu suất KTV"-->
<!--                    android:textSize="14sp"-->
<!--                    android:textStyle="bold"-->
<!--                    android:textColor="#0F172A"-->
<!--                    android:layout_marginBottom="12dp" />-->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvThongKeKtv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
        </androidx.cardview.widget.CardView>

        <!-- AI Phân tích: nút + trạng thái -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="✨ AI Phân tích &amp; Gợi ý"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#0F172A" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTaoInsight"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Phân tích"
                        android:textSize="12sp"
                        android:paddingHorizontal="14dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="@color/primary"
                        android:textColor="@color/primary" />
                </LinearLayout>
                <!-- Trạng thái / tóm tắt tổng thể -->
                <TextView
                    android:id="@+id/tvAiInsight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nhấn 'Phân tích' để AI tự động gom cụm và đưa ra gợi ý."
                    android:textSize="13sp"
                    android:textColor="#64748B"
                    android:lineSpacingMultiplier="1.5" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Các cụm vấn đề do AI tạo ra (render động) -->
        <LinearLayout
            android:id="@+id/llCumDeContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="4dp" />



    </LinearLayout>
</ScrollView>
