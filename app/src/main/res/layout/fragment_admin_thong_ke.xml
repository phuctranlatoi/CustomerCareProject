<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Bộ lọc thời gian -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button android:id="@+id/btnTuan"
                android:layout_width="0dp" android:layout_height="36dp"
                android:layout_weight="1" android:layout_marginEnd="4dp"
                android:text="Tuần" android:textSize="13sp"
                android:backgroundTint="@color/primary" />

            <Button android:id="@+id/btnThang"
                android:layout_width="0dp" android:layout_height="36dp"
                android:layout_weight="1" android:layout_marginStart="4dp"
                android:text="Tháng" android:textSize="13sp"
                android:backgroundTint="@color/divider" />
        </LinearLayout>

        <!-- Thẻ tổng quan -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                app:cardCornerRadius="10dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:id="@+id/tvTongDanhGia"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="28sp" android:textStyle="bold"
                        android:textColor="@color/primary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Đánh giá" android:textSize="12sp" android:textColor="@color/text_secondary" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="6dp"
                app:cardCornerRadius="10dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:id="@+id/tvTongTicket"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="28sp" android:textStyle="bold"
                        android:textColor="@color/accent" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Yêu cầu HT" android:textSize="12sp" android:textColor="@color/text_secondary" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Tỷ lệ hài lòng -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="10dp" app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Tỷ lệ hài lòng" android:textSize="14sp"
                    android:textStyle="bold" android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/tvHaiLong"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center"
                        android:textColor="@color/success" android:textSize="13sp" />
                    <TextView android:id="@+id/tvTrungBinh"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center"
                        android:textColor="@color/warning" android:textSize="13sp" />
                    <TextView android:id="@+id/tvKhongHaiLong"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center"
                        android:textColor="@color/error" android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Thống kê theo sản phẩm -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="10dp" app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Đánh giá theo sản phẩm" android:textSize="14sp"
                    android:textStyle="bold" android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvThongKeSanPham"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Top tags NLP -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardCornerRadius="10dp" app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Chủ đề góp ý nhiều nhất (AI Tags)" android:textSize="14sp"
                    android:textStyle="bold" android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />
                <TextView android:id="@+id/tvTopTags"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="14sp" android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.6" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
