<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Bộ lọc thời gian -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@color/white"
            android:layout_marginBottom="16dp">

            <Button android:id="@+id/btnTuan"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="7 ngày qua"
                android:textSize="13sp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary" />

            <Button android:id="@+id/btnThang"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="30 ngày qua"
                android:textSize="13sp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="@color/text_secondary"
                android:backgroundTint="@color/background" />
        </LinearLayout>

        <!-- 4 thẻ tổng quan -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:layout_marginBottom="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                app:cardCornerRadius="12dp" app:cardElevation="3dp"
                app:cardBackgroundColor="@color/primary">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:id="@+id/tvTongDanhGia"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="32sp" android:textStyle="bold"
                        android:textColor="@color/white" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Đánh giá SP" android:textSize="12sp" android:textColor="#CCE3F2FD" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                app:cardCornerRadius="12dp" app:cardElevation="3dp"
                app:cardBackgroundColor="#FF6F00">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:id="@+id/tvTongTicket"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="32sp" android:textStyle="bold"
                        android:textColor="@color/white" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Yêu cầu HT" android:textSize="12sp" android:textColor="#CCFFF3E0" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                app:cardCornerRadius="12dp" app:cardElevation="3dp"
                app:cardBackgroundColor="@color/success">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:id="@+id/tvTongDanhGiaKtv"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="32sp" android:textStyle="bold"
                        android:textColor="@color/white" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Đánh giá KTV" android:textSize="12sp" android:textColor="#CCE8F5E9" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                app:cardCornerRadius="12dp" app:cardElevation="3dp"
                app:cardBackgroundColor="#7B1FA2">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:id="@+id/tvDiemTBKtv"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0.0★" android:textSize="28sp" android:textStyle="bold"
                        android:textColor="@color/white" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Điểm TB KTV" android:textSize="12sp" android:textColor="#CCF3E5F9" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </GridLayout>

        <!-- Trạng thái Ticket -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp" app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📋 Trạng thái Ticket" android:textSize="15sp"
                    android:textStyle="bold" android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="@color/warning" android:layout_marginEnd="8dp"
                        android:layout_gravity="center_vertical" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Chờ xử lý"
                        android:textColor="@color/text_primary" android:textSize="13sp" />
                    <TextView android:id="@+id/tvTicketChoXuLy"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/warning"
                        android:textStyle="bold" android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="@color/primary" android:layout_marginEnd="8dp"
                        android:layout_gravity="center_vertical" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Đang xử lý"
                        android:textColor="@color/text_primary" android:textSize="13sp" />
                    <TextView android:id="@+id/tvTicketDangXuLy"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/primary"
                        android:textStyle="bold" android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="@color/success" android:layout_marginEnd="8dp"
                        android:layout_gravity="center_vertical" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Đã xử lý"
                        android:textColor="@color/text_primary" android:textSize="13sp" />
                    <TextView android:id="@+id/tvTicketDaXuLy"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/success"
                        android:textStyle="bold" android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tỷ lệ hài lòng sản phẩm -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp" app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="😊 Tỷ lệ hài lòng (Sản phẩm)" android:textSize="15sp"
                    android:textStyle="bold" android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <!-- Hài lòng -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                        android:text="😊 Hài lòng" android:textSize="12sp" android:textColor="@color/success" />
                    <ProgressBar android:id="@+id/pbHaiLong"
                        android:layout_width="0dp" android:layout_height="10dp"
                        android:layout_weight="1" android:layout_marginHorizontal="8dp"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:progressTint="@color/success"
                        android:progressBackgroundTint="@color/star_inactive"
                        android:max="100" android:progress="0" />
                    <TextView android:id="@+id/tvHaiLong"
                        android:layout_width="40dp" android:layout_height="wrap_content"
                        android:text="0%" android:textSize="12sp" android:textColor="@color/success"
                        android:textStyle="bold" android:gravity="end" />
                </LinearLayout>

                <!-- Trung bình -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                        android:text="😐 Trung bình" android:textSize="12sp" android:textColor="@color/warning" />
                    <ProgressBar android:id="@+id/pbTrungBinh"
                        android:layout_width="0dp" android:layout_height="10dp"
                        android:layout_weight="1" android:layout_marginHorizontal="8dp"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:progressTint="@color/warning"
                        android:progressBackgroundTint="@color/star_inactive"
                        android:max="100" android:progress="0" />
                    <TextView android:id="@+id/tvTrungBinh"
                        android:layout_width="40dp" android:layout_height="wrap_content"
                        android:text="0%" android:textSize="12sp" android:textColor="@color/warning"
                        android:textStyle="bold" android:gravity="end" />
                </LinearLayout>

                <!-- Không hài lòng -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                        android:text="😞 Không HL" android:textSize="12sp" android:textColor="@color/error" />
                    <ProgressBar android:id="@+id/pbKhongHaiLong"
                        android:layout_width="0dp" android:layout_height="10dp"
                        android:layout_weight="1" android:layout_marginHorizontal="8dp"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:progressTint="@color/error"
                        android:progressBackgroundTint="@color/star_inactive"
                        android:max="100" android:progress="0" />
                    <TextView android:id="@+id/tvKhongHaiLong"
                        android:layout_width="40dp" android:layout_height="wrap_content"
                        android:text="0%" android:textSize="12sp" android:textColor="@color/error"
                        android:textStyle="bold" android:gravity="end" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Đánh giá theo sản phẩm -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp" app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📦 Đánh giá theo Sản phẩm" android:textSize="15sp"
                    android:textStyle="bold" android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvThongKeSanPham"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Hiệu suất & đánh giá KTV -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp" app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="👨‍🔧 Hiệu suất &amp; Đánh giá KTV" android:textSize="15sp"
                    android:textStyle="bold" android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvThongKeKtv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- AI Insight tổng hợp -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp" app:cardElevation="3dp"
            app:cardBackgroundColor="#E8F5E9">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🤖 AI Insight (Gemini)" android:textSize="15sp"
                        android:textStyle="bold" android:textColor="@color/text_primary" />
                    <Button android:id="@+id/btnTaoInsight"
                        android:layout_width="wrap_content" android:layout_height="32dp"
                        android:text="Phân tích" android:textSize="12sp"
                        android:paddingHorizontal="12dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                </LinearLayout>
                <TextView android:id="@+id/tvAiInsight"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Nhấn 'Phân tích' để Gemini tổng hợp insight từ các đánh giá."
                    android:textSize="13sp" android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.5" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Top tags NLP -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp" app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🏷️ Chủ đề góp ý nhiều nhất" android:textSize="15sp"
                    android:textStyle="bold" android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupTags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
                <TextView android:id="@+id/tvTopTags"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="@color/text_secondary"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
