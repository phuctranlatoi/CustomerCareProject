<?xml version="1.0" encoding="utf-8"?>
<!-- Example: Product item using Material3Card component -->
<!-- This is an enhanced version of item_san_pham.xml using Material3Card -->
<com.example.customercareproject.ui.components.Material3Card xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="5dp"
    app:cornerRadiusSize="large"
    app:cardClickable="true"
    app:enableHoverEffect="true"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Icon emoji nền tròn -->
        <TextView
            android:id="@+id/tvIconSanPham"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_avatar_circle"
            android:gravity="center"
            android:textSize="22sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTenSanPham"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/tvMoTaSanPham"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="22sp"
            android:textColor="?attr/colorOutline" />
    </LinearLayout>

</com.example.customercareproject.ui.components.Material3Card>
