<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    >

    <!-- Top bar with Material Design 3 styling -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:gravity="center_vertical"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="Quay lại" />

        <TextView
            android:id="@+id/tvTieuDeToolbar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chi tiết lỗi"
            android:textAppearance="@style/TextAppearance.App.TitleLarge"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card tiêu đề lỗi using Material3Card -->
            <com.example.customercareproject.ui.components.Material3Card
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cornerRadiusSize="large"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvTieuDe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.App.HeadlineSmall"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/tvSanPham"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.App.LabelMedium"
                        android:textColor="?attr/colorPrimary"
                        
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="3dp"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.example.customercareproject.ui.components.Material3Card>

            <!-- Card mô tả lỗi using Material3Card -->
            <com.example.customercareproject.ui.components.Material3Card
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cornerRadiusSize="large"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mô tả lỗi"
                        android:textAppearance="@style/TextAppearance.App.TitleMedium"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/tvMoTa"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.App.BodyLarge"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        
                        android:padding="12dp" />
                </LinearLayout>
            </com.example.customercareproject.ui.components.Material3Card>

            <!-- Card hướng dẫn giải quyết using Material3Card -->
            <com.example.customercareproject.ui.components.Material3Card
                android:id="@+id/cardHuongDan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cornerRadiusSize="large"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/success_container"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cách giải quyết"
                        app:drawableStartCompat="@drawable/ic_check_circle"
                        android:drawablePadding="8dp"
                        android:textAppearance="@style/TextAppearance.App.TitleMedium"
                        android:textColor="@color/on_success_container"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/tvCachGiaiQuyet"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.App.BodyLarge"
                        android:textColor="@color/on_success_container" />
                </LinearLayout>
            </com.example.customercareproject.ui.components.Material3Card>

            <com.example.customercareproject.ui.components.Material3Button
                android:id="@+id/btnDaTuXuLy"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Tôi đã tự xử lý được"
                android:textAppearance="@style/TextAppearance.App.LabelLarge"
                app:cornerRadius="@dimen/shape_corner_medium"
                app:backgroundTint="@color/success"
                android:textColor="@color/on_success"
                android:layout_marginBottom="10dp"
                android:visibility="gone" />

            <com.example.customercareproject.ui.components.Material3Button
                android:id="@+id/btnYeuCauHoTro"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Gửi yêu cầu hỗ trợ kỹ thuật"
                android:textAppearance="@style/TextAppearance.App.LabelLarge"
                app:cornerRadius="@dimen/shape_corner_medium"
                app:backgroundTint="?attr/colorPrimary"
                android:textColor="?attr/colorOnPrimary" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>

