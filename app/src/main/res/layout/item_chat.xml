<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="8dp"
    android:paddingVertical="3dp">

    <!-- Tin nhắn từ KTV (phải - xanh đậm) -->
    <LinearLayout
        android:id="@+id/layoutKtv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingStart="60dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_bubble_ktv"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:maxWidth="260dp">

            <TextView
                android:id="@+id/tvNoiDungKtv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="@color/white"
                android:lineSpacingMultiplier="1.3" />

            <TextView
                android:id="@+id/tvThoiGianKtv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#90CAF9"
                android:layout_marginTop="4dp"
                android:layout_gravity="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Tin nhắn từ Khách hàng (trái - trắng) -->
    <LinearLayout
        android:id="@+id/layoutKh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start"
        android:paddingEnd="60dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_bubble_kh"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:maxWidth="260dp">

            <TextView
                android:id="@+id/tvTenNguoiGui"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvNoiDungKh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.3" />

            <TextView
                android:id="@+id/tvThoiGianKh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
