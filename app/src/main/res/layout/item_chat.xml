<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="0dp"
    android:paddingVertical="4dp">

    <!-- Tin nhắn từ KTV (phải - gradient xanh) -->
    <LinearLayout
        android:id="@+id/layoutKtv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingStart="60dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_bubble_ktv"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:maxWidth="280dp">

            <TextView
                android:id="@+id/tvNoiDungKtv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="?attr/colorOnPrimary"
                android:lineSpacingMultiplier="1.3" />

            <TextView
                android:id="@+id/tvThoiGianKtv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="4dp"
                android:layout_gravity="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Tin nhắn từ Khách hàng (trái - trắng) -->
    <LinearLayout
        android:id="@+id/layoutKh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start"
        android:paddingEnd="60dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_bubble_kh"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:maxWidth="280dp">

            <TextView
                android:id="@+id/tvTenNguoiGui"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvNoiDungKh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="?attr/colorOnSurface"
                android:lineSpacingMultiplier="1.3" />

            <TextView
                android:id="@+id/tvThoiGianKh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
