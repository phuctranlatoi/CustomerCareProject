<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    >

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="?attr/colorSurface"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:gravity="center_vertical"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="Quay lại" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chi tiết yêu cầu"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card thông tin ticket -->
            <com.example.customercareproject.ui.components.Material3Card app:cornerRadiusSize="medium" app:cardClickable="true" app:enableHoverEffect="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                
                
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YÊU CẦU HỖ TRỢ"
                        android:textSize="10sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvTieuDe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvSanPham"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="?attr/colorPrimary"
                            
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="3dp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/tvUuTienDetail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="3dp"
                             />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvMoTa"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginTop="14dp"
                        android:lineSpacingMultiplier="1.6"
                        
                        android:padding="12dp" />
                </LinearLayout>
            </com.example.customercareproject.ui.components.Material3Card>

            <!-- Card thông tin khách hàng -->
            <com.example.customercareproject.ui.components.Material3Card app:cornerRadiusSize="medium" app:cardClickable="true" app:enableHoverEffect="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                
                
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KHÁCH HÀNG"
                        android:textSize="10sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="14dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="Họ tên"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                        <TextView
                            android:id="@+id/tvHoTen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="SĐT"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                        <TextView
                            android:id="@+id/tvSdt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="Email"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                        <TextView
                            android:id="@+id/tvEmailKh"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>
                </LinearLayout>
            </com.example.customercareproject.ui.components.Material3Card>

            <!-- Card ghi chú tiến độ KTV Handoff -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                
                
                app:strokeWidth="2dp"
                app:strokeColor="?attr/colorPrimaryContainer"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Header with icon -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_nav_tickets"
                            app:tint="?attr/colorPrimary"
                            android:layout_marginEnd="12dp"
                            android:contentDescription="Progress notes" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lịch sử hỗ trợ"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ghi chú tiến độ để KTV khác tiếp tục"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Danh sách ghi chú -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvGhiChu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <TextView
                        android:id="@+id/tvGhiChuTrong"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Chưa có ghi chú nào.\nHãy thêm ghi chú đầu tiên để theo dõi tiến độ."
                        app:drawableTopCompat="@drawable/ic_note"
                        android:drawablePadding="8dp"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:gravity="center"
                        android:padding="24dp"
                        android:visibility="gone" />

                    <!-- Nút xem lịch sử note toàn bộ của KH trên sản phẩm này -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnXemLichSuNote"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📋 Xem lịch sử Note trên sản phẩm này"
                        android:textSize="13sp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="4dp"
                        app:cornerRadius="10dp"
                        app:icon="@drawable/ic_nav_tickets"
                        app:iconGravity="textStart" />

                    <!-- Form nhập ghi chú mới (ẩn khi DaXuLy) -->
                    <LinearLayout
                        android:id="@+id/layoutNhapGhiChu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp">

                        <!-- Quick note preset chips -->
                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:scrollbars="none"
                            android:layout_marginBottom="8dp">

                            <com.google.android.material.chip.ChipGroup
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:singleLine="true">

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chipDangKiemTra"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Đang kiểm tra"
                                    style="@style/Widget.MaterialComponents.Chip.Action" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chipChoPhanhoi"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Chờ phản hồi khách"
                                    style="@style/Widget.MaterialComponents.Chip.Action" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chipDaLienHe"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Đã liên hệ điện thoại"
                                    style="@style/Widget.MaterialComponents.Chip.Action" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chipDaGiaiQuyet"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Đã giải quyết"
                                    style="@style/Widget.MaterialComponents.Chip.Action" />

                            </com.google.android.material.chip.ChipGroup>
                        </HorizontalScrollView>

                        <com.example.customercareproject.ui.components.Material3TextField
                            android:id="@+id/edtGhiChu"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:hint="Nhập ghi chú tiến độ..."
                            android:inputType="textMultiLine"
                            android:minLines="2"
                            app:boxCornerRadiusBottomEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusTopStart="10dp" />

                        <com.example.customercareproject.ui.components.Material3Button
                            android:id="@+id/btnLuuGhiChu"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:layout_gravity="end"
                            android:text="Lưu ghi chú"
                            android:textSize="13sp"
                            app:cornerRadius="10dp"
                            app:backgroundTint="?attr/colorPrimary"
                            android:textColor="?attr/colorOnPrimary" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        
        android:elevation="8dp">

        <com.example.customercareproject.ui.components.Material3Button
            android:id="@+id/btnNhanTin"
            android:layout_width="0dp"
            android:layout_height="65dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Nhắn tin"
            android:textSize="14sp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:icon="@drawable/ic_chat" />

        <com.example.customercareproject.ui.components.Material3Button
            android:id="@+id/btnGoiDienDetail"
            android:layout_width="0dp"
            android:layout_height="65dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Gọi điện"
            android:textSize="14sp"
            style="@style/Widget.Material3.Button.TonalButton"
            app:icon="@drawable/ic_call" />

        <com.example.customercareproject.ui.components.Material3Button
            android:id="@+id/btnDongTicket"
            android:layout_width="0dp"
            android:layout_height="65dp"
            android:layout_weight="1"
            android:text="Đóng ticket"
            android:textSize="14sp"
            style="@style/Widget.Material3.Button"
            app:icon="@drawable/ic_check_circle" />
    </LinearLayout>

</LinearLayout>




