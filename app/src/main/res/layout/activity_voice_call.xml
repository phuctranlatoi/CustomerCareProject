<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/primary_dark"
    android:padding="32dp">

    <!-- Avatar vòng tròn -->
    <LinearLayout
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:gravity="center"
        android:background="@drawable/bg_icon_circle"
        android:layout_marginBottom="20dp">
        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_call"
            android:tint="@color/on_primary"
            android:contentDescription="Avatar" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvCalleeName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tên người dùng"
        android:textColor="@color/on_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvCallStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đang kết nối..."
        android:textColor="@color/inverse_primary"
        android:textSize="15sp"
        android:layout_marginBottom="56dp" />

    <!-- Mic + Loa -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="40dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="28dp">

            <ImageButton
                android:id="@+id/btnMute"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_icon_circle"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                android:tint="@color/on_primary"
                android:padding="14dp"
                android:contentDescription="Tắt mic" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mic"
                android:textColor="@color/inverse_primary"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="28dp">

            <ImageButton
                android:id="@+id/btnSpeaker"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_icon_circle"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                android:tint="@color/on_primary"
                android:alpha="0.5"
                android:padding="14dp"
                android:contentDescription="Loa ngoài" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loa"
                android:textColor="@color/inverse_primary"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Nút cúp máy -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <ImageButton
            android:id="@+id/btnHangup"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_btn_send"
            android:src="@android:drawable/ic_menu_call"
            android:tint="@color/on_primary"
            android:padding="16dp"
            android:contentDescription="Cúp máy" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cúp máy"
            android:textColor="@color/error"
            android:textSize="12sp"
            android:layout_marginTop="8dp" />
    </LinearLayout>

</LinearLayout>
