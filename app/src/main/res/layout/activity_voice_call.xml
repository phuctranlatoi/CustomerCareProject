<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#1A237E"
    android:padding="32dp">

    <!-- Avatar placeholder -->
    <ImageView
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:src="@android:drawable/ic_menu_call"
        android:tint="#FFFFFF"
        android:layout_marginBottom="24dp"
        android:contentDescription="Avatar" />

    <TextView
        android:id="@+id/tvCalleeName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tên người dùng"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvCallStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đang kết nối..."
        android:textColor="#B0BEC5"
        android:textSize="16sp"
        android:layout_marginBottom="64dp" />

    <!-- Nút điều khiển -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <!-- Mute -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="24dp">

            <ImageButton
                android:id="@+id/btnMute"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_icon_circle"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                android:tint="#FFFFFF"
                android:padding="14dp"
                android:contentDescription="Tắt mic" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mic"
                android:textColor="#B0BEC5"
                android:textSize="12sp"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- Speaker -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="24dp">

            <ImageButton
                android:id="@+id/btnSpeaker"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_icon_circle"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                android:tint="#FFFFFF"
                android:alpha="0.5"
                android:padding="14dp"
                android:contentDescription="Loa ngoài" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loa"
                android:textColor="#B0BEC5"
                android:textSize="12sp"
                android:layout_marginTop="6dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Nút cúp máy -->
    <ImageButton
        android:id="@+id/btnHangup"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="@drawable/bg_btn_send"
        android:src="@android:drawable/ic_menu_call"
        android:tint="#FFFFFF"
        android:padding="16dp"
        android:contentDescription="Cúp máy" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cúp máy"
        android:textColor="#EF9A9A"
        android:textSize="12sp"
        android:layout_marginTop="8dp" />

</LinearLayout>
