<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/forgotPasswordContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Hero section with icon and title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="80dp"
            android:paddingBottom="32dp"
            android:paddingHorizontal="28dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@android:drawable/ic_dialog_email"
                android:tint="?attr/colorPrimary"
                android:contentDescription="Email icon"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quên mật khẩu"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nhập email đã đăng ký. Chúng tôi sẽ gửi link đặt lại mật khẩu cho bạn."
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.5" />
        </LinearLayout>

        <!-- Form section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingBottom="32dp">

            <!-- Email field with Material3TextField -->
            <com.example.customercareproject.ui.components.Material3TextField
                android:id="@+id/txtEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:layout_marginBottom="24dp"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary" />

            <!-- Submit button with Material3Button -->
            <com.example.customercareproject.ui.components.Material3Button
                android:id="@+id/btnGuiEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Gửi email đặt lại"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="?attr/colorPrimary"
                app:cornerRadius="@dimen/shape_corner_small"
                android:layout_marginBottom="24dp" />

            <!-- Back to login link -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center_horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhớ mật khẩu? "
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tvQuayLai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quay lại đăng nhập"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
