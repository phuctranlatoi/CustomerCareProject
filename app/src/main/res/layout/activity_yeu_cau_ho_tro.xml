<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="?attr/colorSurface">

    <!-- Top bar with Material Design 3 styling -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="?attr/colorSurface"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:gravity="center_vertical"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="Quay lại" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Yêu cầu hỗ trợ"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card vấn đề với Material Design 3 styling -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="@dimen/shape_corner_large"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainer"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VẤN ĐỀ"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvTieuDeLoi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorOnSurface" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/tvSanPhamLoi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:chipBackgroundColor="?attr/colorPrimaryContainer"
                        app:chipStrokeWidth="0dp"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card thông tin liên hệ với Material3TextField -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="@dimen/shape_corner_large"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainer"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="THÔNG TIN LIÊN HỆ"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="16dp" />

                    <com.example.customercareproject.ui.components.Material3TextField
                        android:id="@+id/tilHoTen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="Họ và tên *"
                        app:boxStrokeColor="?attr/colorPrimary"
                        app:hintTextColor="?attr/colorPrimary"
                        app:boxCornerRadiusTopStart="@dimen/shape_corner_medium"
                        app:boxCornerRadiusTopEnd="@dimen/shape_corner_medium"
                        app:boxCornerRadiusBottomStart="@dimen/shape_corner_medium"
                        app:boxCornerRadiusBottomEnd="@dimen/shape_corner_medium" />

                    <com.example.customercareproject.ui.components.Material3TextField
                        android:id="@+id/tilSoDienThoai"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="Số điện thoại *"
                        app:boxStrokeColor="?attr/colorPrimary"
                        app:hintTextColor="?attr/colorPrimary"
                        app:boxCornerRadiusTopStart="@dimen/shape_corner_medium"
                        app:boxCornerRadiusTopEnd="@dimen/shape_corner_medium"
                        app:boxCornerRadiusBottomStart="@dimen/shape_corner_medium"
                        app:boxCornerRadiusBottomEnd="@dimen/shape_corner_medium" />

                    <com.example.customercareproject.ui.components.Material3TextField
                        android:id="@+id/tilEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Email"
                        app:boxStrokeColor="?attr/colorPrimary"
                        app:hintTextColor="?attr/colorPrimary"
                        app:boxCornerRadiusTopStart="@dimen/shape_corner_medium"
                        app:boxCornerRadiusTopEnd="@dimen/shape_corner_medium"
                        app:boxCornerRadiusBottomStart="@dimen/shape_corner_medium"
                        app:boxCornerRadiusBottomEnd="@dimen/shape_corner_medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card mô tả vấn đề với Material3TextField -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="@dimen/shape_corner_large"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainer"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MÔ TẢ VẤN ĐỀ"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="16dp" />

                    <!-- Tiêu đề vấn đề — chỉ hiện khi không có lỗi cụ thể -->
                    <com.example.customercareproject.ui.components.Material3TextField
                        android:id="@+id/tilTieuDe"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone"
                        android:hint="Tiêu đề vấn đề *"
                        app:boxStrokeColor="?attr/colorPrimary"
                        app:hintTextColor="?attr/colorPrimary"
                        app:boxCornerRadiusTopStart="@dimen/shape_corner_medium"
                        app:boxCornerRadiusTopEnd="@dimen/shape_corner_medium"
                        app:boxCornerRadiusBottomStart="@dimen/shape_corner_medium"
                        app:boxCornerRadiusBottomEnd="@dimen/shape_corner_medium" />

                    <com.example.customercareproject.ui.components.Material3TextField
                        android:id="@+id/tilMoTaVanDe"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Mô tả chi tiết vấn đề bạn gặp phải..."
                        app:boxStrokeColor="?attr/colorPrimary"
                        app:hintTextColor="?attr/colorPrimary"
                        app:boxCornerRadiusTopStart="@dimen/shape_corner_medium"
                        app:boxCornerRadiusTopEnd="@dimen/shape_corner_medium"
                        app:boxCornerRadiusBottomStart="@dimen/shape_corner_medium"
                        app:boxCornerRadiusBottomEnd="@dimen/shape_corner_medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Loading indicator -->
            <ProgressBar
                android:id="@+id/progressBarGui"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                android:indeterminateTint="?attr/colorPrimary" />

            <!-- Submit button using Material3Button -->
            <com.example.customercareproject.ui.components.Material3Button
                android:id="@+id/btnGuiYeuCau"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Gửi yêu cầu hỗ trợ"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                app:cornerRadius="@dimen/shape_corner_large"
                app:backgroundTint="?attr/colorPrimary"
                android:textColor="?attr/colorOnPrimary"
                app:icon="@drawable/ic_send"
                app:iconGravity="textStart" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
