<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/loginContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Hero gradient background section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_gradient_primary"
            android:gravity="center"
            android:paddingTop="48dp"
            android:paddingBottom="48dp"
            android:paddingHorizontal="28dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@android:drawable/ic_dialog_info"
                android:tint="?attr/colorOnPrimary"
                android:contentDescription="Logo"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chăm Sóc Khách Hàng"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnPrimary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đăng nhập để tiếp tục"
                android:textSize="16sp"
                android:textColor="?attr/colorOnPrimary"
                android:alpha="0.9" />
        </LinearLayout>

        <!-- Form section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="-24dp"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

            <!-- Email field with Material3TextField -->
            <com.example.customercareproject.ui.components.Material3TextField
                android:id="@+id/txtEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:layout_marginBottom="16dp"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary" />

            <!-- Password field with Material3TextField -->
            <com.example.customercareproject.ui.components.Material3TextField
                android:id="@+id/txtPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Mật khẩu"
                android:inputType="textPassword"
                android:layout_marginBottom="8dp"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary"
                app:endIconMode="password_toggle" />

            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quên mật khẩu?"
                android:textColor="?attr/colorPrimary"
                android:layout_gravity="end"
                android:padding="8dp"
                android:layout_marginBottom="24dp"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Login button with Material3Button -->
            <com.example.customercareproject.ui.components.Material3Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Đăng nhập"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="?attr/colorPrimary"
                android:layout_marginBottom="16dp"
                app:cornerRadius="@dimen/shape_corner_small" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="@color/divider" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="  hoặc  " android:textColor="?attr/colorOnSurfaceVariant" android:textSize="13sp" />
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="@color/divider" />
            </LinearLayout>

            <!-- Google login button with Material3Button -->
            <com.example.customercareproject.ui.components.Material3Button
                android:id="@+id/btnGoogleLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Đăng nhập với Google"
                android:textColor="?attr/colorOnSurface"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="@color/outline"
                app:strokeWidth="1dp"
                app:cornerRadius="@dimen/shape_corner_small"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center_horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Chưa có tài khoản? " android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tvRegister"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đăng ký ngay"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
