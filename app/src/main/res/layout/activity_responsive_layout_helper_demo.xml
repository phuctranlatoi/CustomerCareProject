<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">
    
    <LinearLayout
        android:id="@+id/infoContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">
        
        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ResponsiveLayoutHelper Demo"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="24dp" />
        
        <!-- Screen Information Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Screen Information"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="12dp" />
                
                <TextView
                    android:id="@+id/tvScreenSize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Screen Size: COMPACT"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="8dp" />
                
                <TextView
                    android:id="@+id/tvScreenWidth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Screen Width: 0dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="8dp" />
                
                <TextView
                    android:id="@+id/tvScreenHeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Screen Height: 0dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="8dp" />
                
                <TextView
                    android:id="@+id/tvIsTablet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Is Tablet: No"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="8dp" />
                
                <TextView
                    android:id="@+id/tvIsLandscape"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Is Landscape: No"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        
        <!-- Responsive Values Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Responsive Values"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="12dp" />
                
                <TextView
                    android:id="@+id/tvResponsiveSpacing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Responsive Spacing: 16dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="8dp" />
                
                <TextView
                    android:id="@+id/tvResponsiveMargin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Responsive Margin: 8dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="8dp" />
                
                <TextView
                    android:id="@+id/tvGridColumns"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Grid Columns: 2"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="8dp" />
                
                <TextView
                    android:id="@+id/tvTwoPaneLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Use Two-Pane Layout: No"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        
        <!-- Demo Card with Responsive Margin -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/demoCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="?attr/colorPrimaryContainer">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Demo Card"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:layout_marginBottom="8dp" />
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="This card uses responsive margin values. The margin adjusts based on screen size: 8dp (compact), 12dp (medium), 16dp (expanded)."
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnPrimaryContainer" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        
        <!-- Demo RecyclerView -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Responsive Grid"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="12dp" />
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="The grid below adjusts its column count based on screen size: 2 columns (compact), 3 columns (medium), 4 columns (expanded)."
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="16dp" />
        
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/demoRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="?attr/colorSurfaceVariant" />
        
        <!-- Usage Instructions -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="?attr/colorSecondaryContainer">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Try This"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnSecondaryContainer"
                    android:layout_marginBottom="8dp" />
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Rotate your device to see how values change\n• Try this demo on different devices (phone, tablet)\n• Observe how spacing, margins, and grid columns adapt"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSecondaryContainer" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        
    </LinearLayout>
    
</ScrollView>
