<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#F5F7FA">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:gravity="center_vertical"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#0F172A"
            android:contentDescription="Quay lại" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat hỗ trợ"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#0F172A" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang kết nối..."
                android:textSize="12sp"
                android:textColor="#94A3B8" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnGoiThoai"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_avatar_circle"
            android:src="@android:drawable/ic_menu_call"
            android:tint="#1976D2"
            android:padding="9dp"
            android:contentDescription="Gọi thoại" />
    </LinearLayout>

    <!-- Chat messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="8dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

    <!-- Input bar -->
    <LinearLayout
        android:id="@+id/layoutInputBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:elevation="6dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtTinNhan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Nhập tin nhắn..."
            android:inputType="textMultiLine|textCapSentences"
            android:imeOptions="actionSend"
            android:maxLines="4"
            android:background="@drawable/bg_input_chat"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:textSize="15sp"
            android:textColor="#0F172A"
            android:textColorHint="#94A3B8" />

        <ImageButton
            android:id="@+id/btnGui"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_btn_primary"
            android:src="@android:drawable/ic_menu_send"
            android:tint="#FFFFFF"
            android:contentDescription="Gửi"
            android:padding="11dp" />
    </LinearLayout>

</LinearLayout>
